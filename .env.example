# =============================================
# AI TRADING PLATFORM - ENVIRONMENT CONFIG
# =============================================

# ---- APP ----
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ---- BINANCE API ----
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_secret_here
BINANCE_TESTNET=true
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_SPOT_BASE_URL=https://api.binance.com
BINANCE_TESTNET_FUTURES_URL=https://testnet.binancefuture.com
BINANCE_TESTNET_SPOT_URL=https://testnet.binance.vision

# ---- POSTGRESQL ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_platform
DB_USER=postgres
DB_PASSWORD=postgres123
DB_POOL_MIN=2
DB_POOL_MAX=10

# ---- REDIS ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- TELEGRAM ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# =============================================
# AI AGENTS — NO API KEY REQUIRED
# =============================================
# The platform uses Codex CLI and Gemini CLI as subprocess agents.
# Both are free to use after a one-time login. No billing required.
#
# ONE-TIME SETUP:
#   npm install -g @openai/codex        # install Codex CLI
#   npm install -g @google/gemini-cli   # install Gemini CLI
#   codex auth login                    # browser OAuth
#   gemini auth login                   # browser OAuth (free tier: 60 req/min)
#
# If CLIs are not installed the system automatically falls back to the
# 5 built-in deterministic rule-based agents. Everything still works.
#
# Optional: override CLI binary path if installed in a non-standard location
CODEX_PATH=codex
GEMINI_PATH=gemini
# =============================================

# ---- TRADING PAIRS ----
TRADING_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT
DEFAULT_TIMEFRAME=15m
SECONDARY_TIMEFRAME=1h
TREND_TIMEFRAME=4h

# ---- TRADING MODE ----
# Options: live | dryrun | replay
TRADING_MODE=dryrun
DRY_RUN_BALANCE=10000
DRY_RUN_LEVERAGE=10
DRY_RUN_FEE_RATE=0.0004
DRY_RUN_SLIPPAGE=0.0002

# ---- RISK MANAGEMENT ----
MAX_DAILY_LOSS_PERCENT=5
MAX_OPEN_POSITIONS=3
MAX_POSITION_SIZE_PERCENT=10
RISK_REWARD_MIN=1.5
COOLDOWN_AFTER_LOSS_MINUTES=30
MAX_LEVERAGE=20
DEFAULT_LEVERAGE=10
VOLATILITY_THRESHOLD=0.05

# ---- SIGNAL ENGINE ----
MIN_CONFIDENCE_SCORE=70
VOLUME_SPIKE_MULTIPLIER=2.0
WHALE_THRESHOLD_USDT=500000
MIN_SIGNAL_INTERVAL_MINUTES=5

# ---- WEBSOCKET ----
WS_RECONNECT_DELAY_MS=5000
WS_MAX_RECONNECT_ATTEMPTS=10
WS_PING_INTERVAL_MS=30000

# ---- DASHBOARD ----
DASHBOARD_PORT=3000
DASHBOARD_API_URL=http://localhost:3001
