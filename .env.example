# =============================================
# AI TRADING PLATFORM - ENVIRONMENT CONFIG
# =============================================
# Start with TRADING_MODE=dryrun. Do not enable live mode until the
# README Safety Checklist Before Live Mode has been completed.

# ---- APP ----
NODE_ENV=development
PORT=3001
BACKEND_PORT=3001
LOG_LEVEL=info

# ---- BINANCE API ----
# Empty values are acceptable for dryrun/replay public market data.
# Live mode rejects empty or placeholder credentials.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_SPOT_BASE_URL=https://api.binance.com
BINANCE_TESTNET_FUTURES_URL=https://testnet.binancefuture.com
BINANCE_TESTNET_SPOT_URL=https://testnet.binance.vision

# Required only when TRADING_MODE=live and BINANCE_TESTNET=false.
LIVE_TRADING_CONFIRMATION=

# ---- POSTGRESQL ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_platform
DB_USER=postgres
DB_PASSWORD=change_me_strong_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# ---- REDIS ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- TELEGRAM ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================
# AI AGENTS - NO API KEY REQUIRED
# =============================================
# The platform uses Codex CLI and Gemini CLI as subprocess agents.
# If CLIs are not installed the system falls back to deterministic agents.
CODEX_PATH=codex
GEMINI_PATH=gemini

# ---- TRADING PAIRS ----
TRADING_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT
DEFAULT_TIMEFRAME=15m
SECONDARY_TIMEFRAME=1h
TREND_TIMEFRAME=4h

# ---- TRADING MODE ----
# Options: live | dryrun | replay
TRADING_MODE=dryrun
DRY_RUN_BALANCE=10000
DRY_RUN_LEVERAGE=10
DRY_RUN_FEE_RATE=0.0004
DRY_RUN_SLIPPAGE=0.0002
DRYRUN_RESTORE_OPEN_POSITIONS=true
DRYRUN_STRICT_RESTORE=false

# ---- RISK MANAGEMENT ----
MAX_DAILY_LOSS_PERCENT=5
MAX_OPEN_POSITIONS=3
MAX_POSITION_SIZE_PERCENT=10
MAX_POSITION_NOTIONAL_PERCENT=10
RISK_REWARD_MIN=1.5
COOLDOWN_AFTER_LOSS_MINUTES=30
MAX_LEVERAGE=20
DEFAULT_LEVERAGE=10
VOLATILITY_THRESHOLD=0.05

# ---- SIGNAL ENGINE ----
MIN_CONFIDENCE_SCORE=70
VOLUME_SPIKE_MULTIPLIER=2.0
WHALE_THRESHOLD_USDT=500000
MIN_SIGNAL_INTERVAL_MINUTES=5

# ---- WEBSOCKET ----
WS_RECONNECT_DELAY_MS=5000
WS_MAX_RECONNECT_ATTEMPTS=10
WS_PING_INTERVAL_MS=30000

# ---- DASHBOARD/API SECURITY ----
DASHBOARD_PORT=3000
# Used only by the Next.js dashboard server-side proxy.
BACKEND_API_URL=http://localhost:3001
# Optional browser-visible Socket.IO URL; this is not an auth token.
NEXT_PUBLIC_API_URL=http://localhost:3001
# Server-only bearer token shared by the backend API and dashboard proxy.
DASHBOARD_API_TOKEN=change_me_dashboard_token
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DASHBOARD_RATE_LIMIT_WINDOW_MS=60000
DASHBOARD_RATE_LIMIT_MAX=120

# ---- FEATURE FLAGS ----
DEBUG_SIGNAL_FLOW=false
ENABLE_DYNAMIC_CONSENSUS=true
ENABLE_RELAXED_MTF=true
ENABLE_SOFT_FAIL_TOLERANCE=true
ENABLE_CHOPPY_TUNING=true
SCORING_ENGINE_SHADOW=true
USE_SCORING_ENGINE=false
